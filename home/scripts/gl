#!/usr/bin/env bash
# gl — git log viewer with vim-like fzf navigation and a delta preview.
#
# KEYS — outer log view (letter keys become literal text after `/`)
#   j / k         move
#   /             open input (filter)
#   q             quit
#   y             copy selected SHA
#   o             open selected commit on GitHub (the commit page links
#                 to its associated PR via GitHub's UI)
#   Enter         open the commit in a 2-pane file browser (file list +
#                 delta preview); from there:
#                   j / k / / / q / Esc — same as outer
#                   Enter   — show the selected file's full diff (paged)
#                   b       — blame the selected file at this commit
#                             (use `,` inside gb to walk back further)
#   Esc / Ctrl-C  input mode: hide input and re-bind nav keys
#                 nav mode:   abort
#
# USAGE
#   gl [git log args...]
#
# EXIT CODES
#   0    fzf returned a selection
#   2    environment / dependency error
#   130  fzf aborted

set -euo pipefail

die() {
  printf 'gl: %s\n' "$*" >&2
  exit 2
}

command -v fzf   >/dev/null 2>&1 || die "fzf not found on PATH"
command -v delta >/dev/null 2>&1 || die "delta not found on PATH"
command -v gh    >/dev/null 2>&1 || die "gh not found on PATH"

# When the user opens any paged delta view (outer commit detail or the
# per-file diff inside the 2-pane browser), wire `y` inside less to
# copy the displayed commit's SHA — exposed as $GL_SHA at execute time.
GL_LESSKEY=$(mktemp)
trap 'rm -f "$GL_LESSKEY"' EXIT
cat > "$GL_LESSKEY" <<'EOF'
#command
y shell printf $GL_SHA | pbcopy\n
EOF
export GL_LESSKEY

# Open the 2-pane file browser for $1 — list of files touched by the
# commit on the left, delta preview of the selected file on the right.
# Pressing `b` jumps into gb for the focused file at this commit.
gl_show_files() {
  local sha=$1
  local files
  # `-M -C` collapses rename / copy pairs into the destination path so
  # a renamed file shows up once instead of as a delete + add pair.
  files=$(git diff-tree --no-commit-id --name-only -M -C -r "$sha")
  [[ -z $files ]] && return

  # Size the file-list pane to the longest filename (+ pointer + space).
  # fzf reserves 4 cells of preview overhead (border + padding), so the
  # rendered list width works out to `cols - pv - 4`. Cap the list at
  # half the terminal so a freakishly long path cannot starve preview.
  local cols left cap pv
  cols=${COLUMNS:-$(tput cols)}
  left=$(awk '{ if (length > m) m = length } END { print m + 3 }' <<< "$files")
  cap=$((cols / 2))
  (( left > cap )) && left=$cap
  pv=$((cols - left - 4))

  printf '%s\n' "$files" |
    fzf --ansi --no-sort \
      --layout=reverse-list \
      --no-input \
      --bind 'j:down,k:up,q:abort,/:show-input+unbind(j,k,q,b,/)' \
      --bind 'esc,ctrl-c:transform:
        if [[ $FZF_INPUT_STATE = enabled ]]; then
          echo "rebind(j,k,q,b,/)+hide-input"
        else
          echo abort
        fi
      ' \
      --preview "git log -p --follow -1 --color=always $sha -- {} | delta --width=\$FZF_PREVIEW_COLUMNS --features=unified" \
      --preview-window="right:${pv}" \
      --header "files in $sha — j/k:nav  /:filter  q/Esc:back  b:blame  <Enter>:full diff" \
      --bind "enter:execute(export GL_SHA=$sha; git log -p --follow -1 --color=always $sha -- {} | delta --paging=always --pager 'less -R --lesskey-src=$GL_LESSKEY')" \
      --bind "b:execute(gb {} $sha)"
}
export -f gl_show_files

cols=${COLUMNS:-$(tput cols)}
main=100
(( cols <= main )) && main=$cols
pv=$((cols - main))

git log --oneline --color=always "$@" |
  SHELL=$(command -v bash) fzf --ansi --no-sort \
    --layout=reverse-list \
    --no-input \
    --bind 'j:down,k:up,q:abort,/:show-input+unbind(j,k,q,y,o,/)' \
    --bind 'esc,ctrl-c:transform:
      if [[ $FZF_INPUT_STATE = enabled ]]; then
        echo "rebind(j,k,q,y,o,/)+hide-input"
      else
        echo abort
      fi
    ' \
    --preview 'git show --color=always {1} | delta --width=$FZF_PREVIEW_COLUMNS --features=unified' \
    --preview-window="right:${pv}" \
    --header 'j/k:nav  /:filter  q/Esc:back/quit  <Enter>:files  y:sha  o:open' \
    --bind 'enter:execute(gl_show_files {1})' \
    --bind 'y:execute-silent(printf %s {1} | pbcopy)' \
    --bind 'o:execute-silent(gh browse {1})'
