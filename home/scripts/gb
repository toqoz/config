#!/usr/bin/env bash
# gb — git blame viewer with vim-like fzf navigation and a tig-style
# parent walk.
#
# KEYS (nav mode — letter keys become literal text after `/`)
#   j / k         move
#   /             open input (filter)
#   q             quit
#   y             copy SHA of the selected line
#   o             open commit on GitHub (the commit page links to its
#                 associated PR via GitHub's UI)
#   ,             re-blame this file at the parent of the selected
#                 commit; q pops back to where you were
#   Enter         show full commit (paged via delta)
#   Esc / Ctrl-C  input mode: hide input and re-bind nav keys
#                 nav mode:   abort
#
# USAGE
#   gb <file> [<rev>]
#
# EXIT CODES
#   0    fzf returned a selection
#   2    environment / dependency / argument error
#   130  fzf aborted

set -euo pipefail

die() {
  printf 'gb: %s\n' "$*" >&2
  exit 2
}

usage() {
  printf 'Usage: gb <file> [<rev>]\n' >&2
  exit 2
}

case ${1:-} in
  -h|--help) printf 'Usage: gb <file> [<rev>]\n'; exit 0 ;;
esac

[[ $# -ge 1 && $# -le 2 ]] || usage
file=$1
rev=${2:-HEAD}

command -v fzf   >/dev/null 2>&1 || die "fzf not found on PATH"
command -v delta >/dev/null 2>&1 || die "delta not found on PATH"
command -v gh    >/dev/null 2>&1 || die "gh not found on PATH"

cols=${COLUMNS:-$(tput cols)}
main=140
(( cols <= main )) && main=$cols
pv=$((cols - main))

# Walk to the parent of $1, but only when the file actually exists
# there — otherwise print why and wait for a keypress so the message
# survives fzf's post-execute redraw. Pressing `,` should never drop
# the user into an empty inner view.
gb_walk_parent() {
  local sha=$1 file=$2 parent="${1}^"
  if ! git rev-parse --verify "${parent}^{commit}" >/dev/null 2>&1; then
    printf 'gb: %s is a boundary commit (no parent to walk to)\n' "$sha" >&2
  else
    # If $sha renamed $file (or copied from another path), walk into
    # the pre-rename path so the line history actually continues.
    # Pathspec on `git log` filters before rename detection, so look at
    # the full diff for $sha and pick the rename whose destination is
    # $file.
    local parent_path
    parent_path=$(git show -M -C --name-status --format= "$sha" 2>/dev/null \
      | awk -F'\t' -v f="$file" '$1 ~ /^[RC]/ && $3 == f { print $2; found=1; exit }
                                  END { if (!found) print f }')
    if ! git cat-file -e "${parent}:${parent_path}" 2>/dev/null; then
      printf 'gb: %s does not exist at %s (added here)\n' "$file" "$parent" >&2
    else
      exec gb "$parent_path" "$parent"
    fi
  fi
  printf '(press any key to return) ' >&2
  read -n 1 -s
  printf '\n' >&2
}
export -f gb_walk_parent

# Bindings consult $GB_FILE rather than re-deriving the path on each
# action; the recursive `,` push reuses the same env so `gb` resolves
# the file relative to the original CWD.
export GB_FILE=$file

# Boundary commits in `git blame` output are prefixed with `^`; strip
# it before passing the SHA to git / gh / a recursive gb.
# `-f` always emits the file path that the line was attributed to;
# this lets `,` follow renames by passing that path (rather than the
# script's static $GB_FILE) to the recursive blame.
git blame -f --date=format:'%Y-%m-%d %H:%M' "$rev" -- "$file" |
  sed 's/(\([^)]*\))/\1/' |
  awk '
    # Per-SHA cycling palette stays within warm hues so it never
    # collides with the fixed green author / blue date / default-fg
    # source.
    BEGIN {
      n = 6; idx = 0
      pal[0] = "31"; pal[1] = "33"; pal[2] = "35"
      pal[3] = "91"; pal[4] = "93"; pal[5] = "95"
      AUTHOR = "32"
      DATE   = "34"
    }
    {
      sha = $1
      rest = substr($0, length(sha) + 2)             # drop "<sha> "

      # File column with its variable alignment padding preserved as
      # `file_pad` so the post-color output keeps the right-aligned
      # columns that git blame -f produces.
      match(rest, /^[^ ]+/)
      file = substr(rest, 1, RLENGTH)
      rest = substr(rest, RLENGTH + 1)
      match(rest, /^ +/)
      file_pad = substr(rest, 1, RLENGTH)
      rest = substr(rest, RLENGTH + 1)

      if (!match(rest, /[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}/)) {
        print; next
      }
      date_str = substr(rest, RSTART, RLENGTH)
      author   = substr(rest, 1, RSTART - 2)         # before " <date>"
      tail     = substr(rest, RSTART + RLENGTH + 1)  # "<line#> <source>"

      if (!(sha in cmap)) { cmap[sha] = pal[idx++ % n] }
      printf "\033[%sm%s\033[0m %s%s\033[%sm%s\033[0m \033[%sm%s\033[0m %s\n",
        cmap[sha], sha, file, file_pad, AUTHOR, author, DATE, date_str, tail
    }
  ' |
  SHELL=$(command -v bash) fzf --ansi --no-sort \
    --layout=reverse-list \
    --no-input \
    --bind 'j:down,k:up,q:abort,/:show-input+unbind(j,k,q,y,o,/)' \
    --bind 'esc,ctrl-c:transform:
      if [[ $FZF_INPUT_STATE = enabled ]]; then
        echo "rebind(j,k,q,y,o,/)+hide-input"
      else
        echo abort
      fi
    ' \
    --preview 's={1}; git show --color=always "${s#^}" | delta --width=$FZF_PREVIEW_COLUMNS --features=unified' \
    --preview-window="right:${pv}" \
    --header "blame: $file @ $rev — j/k:nav  /:filter  q/Esc:back/quit  ,:parent  <Enter>:details  y:sha  o:open" \
    --bind 'enter:execute(s={1}; git show --color=always "${s#^}" | delta --paging=always)' \
    --bind 'y:execute-silent(s={1}; printf "%s" "${s#^}" | _copy)' \
    --bind 'o:execute-silent(s={1}; gh browse "${s#^}")' \
    --bind ',:transform:
      if [[ $FZF_INPUT_STATE = enabled ]]; then
        echo "put(,)"
      else
        echo "execute(s={1}; f={2}; gb_walk_parent \"\${s#^}\" \"\$f\")"
      fi
    '
