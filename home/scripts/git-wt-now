#!/usr/bin/env bash
# git-wt-now — temporary worktree branches: create, rename, merge.
#
# SUBCOMMANDS
#   (none)   Create a wt-now/<base>/<UTC-timestamp> branch and worktree
#            off the repo's default branch via `git wt`. Prints the
#            worktree path on stdout. Records the base branch in
#            `branch.<branch>.wtNowBase` so later `rename`/`merge` can
#            recover it after the branch has been renamed.
#
#   rename   Derive a final `<type>/<kebab-slug>` name from the
#            committed work via `codex exec`, then rename the branch
#            and move the worktree directory accordingly. Operates on
#            the current worktree if invoked inside a managed one;
#            otherwise picks via `fzf`. Aborts on dirty / no commits /
#            invalid codex output.
#
#   merge    Rebase the wt onto its base, fast-forward merge into base,
#            then remove the worktree and delete the branch. Personal
#            repos only (default: $HOME/src/github.com/toqoz/, override
#            via $WT_NOW_PERSONAL_PREFIX). Aborts on dirty.
#
# EXIT CODES
#   0   success
#   2   environment / git error
#   64  invalid arguments / unknown subcommand

set -euo pipefail

WT_NOW_PREFIX="wt-now"
TIMESTAMP_RE='[0-9]{8}-[0-9]{6}'
PERSONAL_REPO_PREFIX="${WT_NOW_PERSONAL_PREFIX:-${HOME}/src/github.com/toqoz/}"
BRANCH_NAME_RE='^(feat|fix|docs|chore|refactor|test|perf|style|ci|revert|build)/[a-z0-9]+(-[a-z0-9]+)*$'

usage() {
  cat <<'EOF'
Usage: git-wt-now [<subcommand>]

Subcommands:
  (none)    Create a wt-now/<base>/<UTC-timestamp> branch and worktree.
            Prints the worktree path on stdout.
  rename    Rename branch+worktree to a codex-derived <type>/<slug>.
  merge     Rebase + ff-only merge into base, then clean up.

Run inside a managed worktree to operate on it; otherwise fzf-pick.
Personal repos only for `merge` (under ~/src/github.com/toqoz/).
EOF
}

die() {
  printf 'git-wt-now: %s\n' "$*" >&2
  exit 2
}

invalid_arg() {
  printf 'git-wt-now: %s\n' "$*" >&2
  usage >&2
  exit 64
}

require_git_tree() {
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 \
    || die "not inside a git working tree"
}

repo_root() {
  local d
  d=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null) \
    || die "not inside a git working tree"
  dirname "$d"
}

detect_default_base() {
  local b=""
  b=$(gh repo view --json defaultBranchRef --jq '.defaultBranchRef.name' 2>/dev/null || true)
  if [ -z "$b" ]; then
    b=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's@^origin/@@' || true)
  fi
  if [ -z "$b" ]; then
    if git show-ref --verify --quiet refs/heads/main; then
      b=main
    elif git show-ref --verify --quiet refs/heads/master; then
      b=master
    fi
  fi
  printf '%s' "$b"
}

# Prefer origin/<base> when at-or-ahead of local; warn on divergence.
resolve_base_ref() {
  local base="$1"
  local local_ref="refs/heads/$base"
  local origin_ref="refs/remotes/origin/$base"

  if git fetch --quiet origin "$base" 2>/dev/null \
    && git rev-parse --verify --quiet "$origin_ref" >/dev/null; then
    if git merge-base --is-ancestor "$local_ref" "$origin_ref" 2>/dev/null; then
      printf '%s' "$origin_ref"
      return
    fi
    if ! git merge-base --is-ancestor "$origin_ref" "$local_ref" 2>/dev/null; then
      printf 'git-wt-now: local %s and origin/%s have diverged; using local\n' "$base" "$base" >&2
    fi
  fi
  printf '%s' "$local_ref"
}

extract_base_from_branch() {
  local b="$1"
  case "$b" in
    "$WT_NOW_PREFIX"/*)
      local rest="${b#${WT_NOW_PREFIX}/}"
      if [[ "$rest" =~ ^(.+)/${TIMESTAMP_RE}$ ]]; then
        printf '%s' "${BASH_REMATCH[1]}"
      fi
      ;;
  esac
}

# Echo "<branch>\t<path>" for branches with branch.<X>.wtNowBase config.
list_managed_worktrees() {
  local out
  out=$(git worktree list --porcelain | awk '
    /^worktree / { p=$2 }
    /^branch /   { if (p) print substr($2, 12) "\t" p; p="" }
    /^detached/  { p="" }
  ')
  local b p
  while IFS=$'\t' read -r b p; do
    [ -z "$b" ] && continue
    if git config --get "branch.${b}.wtNowBase" >/dev/null 2>&1; then
      printf '%s\t%s\n' "$b" "$p"
    fi
  done <<< "$out"
}

pick_managed_target() {
  command -v fzf >/dev/null 2>&1 || die "fzf not found on PATH"
  local lines
  lines=$(list_managed_worktrees)
  [ -n "$lines" ] || die "no git-wt-now-managed worktrees found"
  local picked
  picked=$(printf '%s\n' "$lines" | fzf --with-nth=1 --delimiter=$'\t' --no-multi) \
    || die "cancelled"
  printf '%s' "$picked"
}

# Echo "<branch>\t<path>" for the target wt: current if managed, else fzf.
resolve_target() {
  local cur_root cur_branch
  if cur_root=$(git rev-parse --show-toplevel 2>/dev/null); then
    cur_branch=$(git -C "$cur_root" symbolic-ref --short HEAD 2>/dev/null || true)
    if [ -n "$cur_branch" ] \
       && git config --get "branch.${cur_branch}.wtNowBase" >/dev/null 2>&1; then
      printf '%s\t%s' "$cur_branch" "$cur_root"
      return
    fi
  fi
  pick_managed_target
}

# Find the worktree currently checked out on the given branch (or empty).
worktree_path_for_branch() {
  local target="$1"
  git worktree list --porcelain | awk -v t="refs/heads/$target" '
    /^worktree / { p=$2 }
    /^branch /   { if ($2 == t) { print p; exit } }
  '
}

cmd_create() {
  require_git_tree
  command -v git-wt >/dev/null 2>&1 || die "git-wt not found on PATH"

  local base
  base=$(detect_default_base)
  [ -n "$base" ] || die "could not determine base branch"

  local base_ref
  base_ref=$(resolve_base_ref "$base")

  local ts
  ts=$(date -u +%Y%m%d-%H%M%S)
  local branch="${WT_NOW_PREFIX}/${base}/${ts}"

  local wt_path
  wt_path=$(git wt --nocd "$branch" "$base_ref") \
    || die "failed to create worktree for $branch"

  git config "branch.${branch}.wtNowBase" "$base"

  printf '%s\n' "$wt_path"
}

cmd_rename() {
  require_git_tree
  command -v codex >/dev/null 2>&1 || die "codex CLI not found on PATH"

  local target branch wt_path
  target=$(resolve_target)
  branch="${target%%$'\t'*}"
  wt_path="${target#*$'\t'}"

  if [ -n "$(git -C "$wt_path" status --porcelain 2>/dev/null)" ]; then
    die "worktree is dirty: $wt_path"
  fi

  local base
  base=$(git config --get "branch.${branch}.wtNowBase" 2>/dev/null || true)
  if [ -z "$base" ]; then
    base=$(extract_base_from_branch "$branch")
  fi
  [ -n "$base" ] || die "could not determine base for $branch"

  local local_base="refs/heads/$base"
  if ! git -C "$wt_path" rev-list "${local_base}..HEAD" --max-count=1 | grep -q .; then
    die "no commits on $branch"
  fi

  local commit_log committed_stat
  commit_log=$(git -C "$wt_path" log --format='%s' "${local_base}..HEAD" 2>/dev/null)
  committed_stat=$(git -C "$wt_path" diff "${local_base}...HEAD" --stat 2>/dev/null)

  printf 'git-wt-now: deriving branch name via codex exec…\n' >&2

  local prompt
  prompt=$(cat <<EOF
Decide a single git branch name for the work below.

Format: <type>/<kebab-slug>
- type ∈ {feat, fix, docs, chore, refactor, test, perf, style, ci, revert, build}
- slug: lowercase letters and digits, hyphen-separated, 2–5 words, concise.

Output exactly the branch name on a single line. No prose, no quotes, no code fence, no markdown.

Commit subjects on this branch:
${commit_log}

Committed diff stat:
${committed_stat}
EOF
  )

  local tmpf
  tmpf=$(mktemp "${TMPDIR:-/tmp}/git-wt-now-codex.XXXXXX")
  # Capture path into the trap string at set time — the local goes out
  # of scope before the EXIT trap fires.
  trap "rm -f '$tmpf'" EXIT

  if ! printf '%s\n' "$prompt" | codex exec --skip-git-repo-check --sandbox read-only -o "$tmpf" >/dev/null 2>&1; then
    die "codex exec failed"
  fi

  local desired
  desired=$(sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//' -e "s/[\\\`'\"]//g" "$tmpf")

  if ! [[ "$desired" =~ $BRANCH_NAME_RE ]]; then
    die "codex returned invalid name: '$desired'"
  fi

  local repo
  repo=$(repo_root)
  local new_path="${repo}/.git/wt/${desired}"
  mkdir -p "$(dirname "$new_path")"

  git -C "$repo" branch -m "$branch" "$desired" \
    || die "branch rename failed"
  if ! git -C "$repo" worktree move "$wt_path" "$new_path"; then
    printf 'git-wt-now: branch renamed to %s but worktree move failed; path is still %s\n' "$desired" "$wt_path" >&2
    exit 2
  fi

  git config "branch.${desired}.wtNowBase" "$base"
  git config --unset "branch.${branch}.wtNowBase" 2>/dev/null || true

  printf 'git-wt-now: renamed %s → %s\n' "$branch" "$desired"
  printf 'git-wt-now: moved worktree to %s\n' "$new_path"
}

cmd_merge() {
  require_git_tree

  local target branch wt_path
  target=$(resolve_target)
  branch="${target%%$'\t'*}"
  wt_path="${target#*$'\t'}"

  local repo
  repo=$(repo_root)
  local repo_real prefix_real
  repo_real=$(cd "$repo" && pwd -P)
  if prefix_real=$(cd "$PERSONAL_REPO_PREFIX" 2>/dev/null && pwd -P); then
    prefix_real="${prefix_real%/}/"
  else
    prefix_real="$PERSONAL_REPO_PREFIX"
  fi
  case "$repo_real/" in
    "$prefix_real"*) ;;
    *) die "merge is only enabled for personal repos under ${PERSONAL_REPO_PREFIX}" ;;
  esac

  if [ -n "$(git -C "$wt_path" status --porcelain 2>/dev/null)" ]; then
    die "worktree is dirty: $wt_path"
  fi

  local base
  base=$(git config --get "branch.${branch}.wtNowBase" 2>/dev/null || true)
  if [ -z "$base" ]; then
    base=$(extract_base_from_branch "$branch")
  fi
  [ -n "$base" ] || die "could not determine base for $branch"

  local local_base="refs/heads/$base"
  if ! git -C "$wt_path" rev-list "${local_base}..HEAD" --max-count=1 | grep -q .; then
    die "no commits to merge on $branch"
  fi

  local base_ref
  base_ref=$(resolve_base_ref "$base")

  printf 'git-wt-now: rebasing %s onto %s…\n' "$branch" "$base_ref" >&2
  if ! git -C "$wt_path" rebase "$base_ref"; then
    git -C "$wt_path" rebase --abort 2>/dev/null || true
    die "rebase onto $base_ref failed; resolve manually"
  fi

  local base_wt_path
  base_wt_path=$(worktree_path_for_branch "$base")

  if [ -n "$base_wt_path" ]; then
    if [ -n "$(git -C "$base_wt_path" status --porcelain 2>/dev/null)" ]; then
      die "base worktree is dirty: $base_wt_path"
    fi
    printf 'git-wt-now: ff-merging %s into %s at %s…\n' "$branch" "$base" "$base_wt_path" >&2
    git -C "$base_wt_path" merge --ff-only "refs/heads/$branch" \
      || die "ff merge failed"
  else
    local tip
    tip=$(git -C "$wt_path" rev-parse HEAD)
    printf 'git-wt-now: updating %s to %s…\n' "$local_base" "$tip" >&2
    git -C "$repo" update-ref "$local_base" "$tip" \
      || die "failed to update $local_base"
  fi

  printf 'git-wt-now: removing worktree and branch…\n' >&2
  git -C "$repo" worktree remove "$wt_path" \
    || die "worktree remove failed"
  git -C "$repo" branch -d "$branch" \
    || die "branch delete failed (use git branch -D)"
  git config --unset "branch.${branch}.wtNowBase" 2>/dev/null || true

  printf 'git-wt-now: merged %s into %s\n' "$branch" "$base"
}

case "${1:-}" in
  rename) shift; cmd_rename "$@" ;;
  merge)  shift; cmd_merge "$@" ;;
  -h|--help) usage; exit 0 ;;
  '') cmd_create ;;
  *) invalid_arg "unknown subcommand: $1" ;;
esac
