emulate -L zsh

# Thin zsh wrapper around home/scripts/git-wt-now so that bare `git-wt-now`
# (no subcommand) cd's into the freshly-created worktree. Subcommands
# (`rename`, `merge`, `-h`, …) are forwarded unchanged and run in $PWD.

if [[ $# -gt 0 ]]; then
  command git-wt-now "$@"
  return $?
fi

local wt_path
wt_path=$(command git-wt-now) || return $?

[[ -d "$wt_path" ]] || {
  echo "git-wt-now: created worktree path missing: $wt_path" >&2
  return 2
}

cd "$wt_path"
