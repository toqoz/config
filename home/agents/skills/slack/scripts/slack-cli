#!/usr/bin/env -S node --experimental-transform-types --no-warnings=ExperimentalWarning
/**
 * slack-cli — unified entry point for Slack operations.
 *
 * Usage:
 *   slack-cli message <get|list|send|edit|delete|draft|react> [args]
 *   slack-cli channel list [--all] [--limit N]
 *   slack-cli search  <messages|files|all> <query> [options]
 *   slack-cli file    download <permalink>
 *   slack-cli auth    <list|import-desktop|import-token --token ...>
 */

const USAGE = `Usage: slack-cli <command> [subcommand] [args]

Commands:
  message   get|list|send|edit|delete|draft|react
  channel   list
  search    messages|files|all <query>
  file      download <permalink>
  auth      list | import-desktop | import-token --token ...

Common options:
  --workspace <url-or-substring>   Select workspace (multi-workspace)

Run 'slack-cli <command>' with no subcommand for detailed help.`;

const cmd = process.argv[2];
const rest = process.argv.slice(3);

const dir = new URL(".", import.meta.url).pathname;
const { FatalError, UsageError } = await import(`${dir}src/helpers/cli.ts`);

try {
  switch (cmd) {
    case "message": case "msg": case "m": {
      const { main } = await import(`${dir}src/message.ts`);
      await main(rest);
      break;
    }
    case "channel": case "ch": case "c": {
      const { main } = await import(`${dir}src/channel.ts`);
      await main(rest);
      break;
    }
    case "search": case "s": {
      const { main } = await import(`${dir}src/search.ts`);
      await main(rest);
      break;
    }
    case "file": case "f": {
      const { main } = await import(`${dir}src/file.ts`);
      await main(rest);
      break;
    }
    case "auth": case "a": {
      const { main } = await import(`${dir}src/auth.ts`);
      await main(rest);
      break;
    }
    default:
      console.error(USAGE);
      process.exit(cmd ? 1 : 0);
  }
} catch (e) {
  if (e instanceof FatalError) {
    console.error(`Error: ${e.message}`);
    process.exit(1);
  }
  if (e instanceof UsageError) {
    console.error(e.message);
    process.exit(1);
  }
  throw e;
}
